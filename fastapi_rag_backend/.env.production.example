APP_NAME=OmniCore RAG Backend
ENVIRONMENT=production
DEBUG=false

API_HOST=0.0.0.0
API_PORT=8000
WEB_CONCURRENCY=2
LOG_LEVEL=info

# Comma-separated values, example: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=
# Comma-separated values, example: api.example.com,localhost
TRUSTED_HOSTS=

POSTGRES_DB=ragdb
POSTGRES_USER=rag
POSTGRES_PASSWORD=replace_me
POSTGRES_DSN=postgresql+asyncpg://rag:replace_me@postgres:5432/ragdb

REDIS_URL=redis://redis:6379/0

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=replace_me
AWS_REGION=us-east-1
S3_BUCKET=rag-files
S3_ENDPOINT_URL=http://minio:9000

VECTOR_DIM=1536
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

OPENAI_API_KEY=replace_me
EMBEDDING_MODEL=text-embedding-3-small

PROACTIVE_ENABLED=true
PROACTIVE_INTERVAL_SECONDS=180
PROACTIVE_CONFIDENCE_THRESHOLD=0.72
PROACTIVE_DEDUPE_MINUTES=240
PROACTIVE_THRESHOLD_MIN=0.45
PROACTIVE_THRESHOLD_MAX=0.95
PROACTIVE_ADJUST_ACCEPT=-0.03
PROACTIVE_ADJUST_IGNORE=0.02
PROACTIVE_ADJUST_DISMISS=0.05

AUTH_SESSION_TTL_HOURS=720
AUTH_MIN_PASSWORD_LENGTH=8
