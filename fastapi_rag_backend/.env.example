APP_NAME=RAG Clarity Backend
ENVIRONMENT=dev
DEBUG=true

API_HOST=0.0.0.0
API_PORT=8000
WEB_CONCURRENCY=2
LOG_LEVEL=info

CORS_ALLOWED_ORIGINS=
TRUSTED_HOSTS=

POSTGRES_DSN=postgresql+asyncpg://rag:rag@localhost:5432/ragdb
REDIS_URL=redis://localhost:6379/0

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=rag-files
S3_ENDPOINT_URL=http://localhost:9000

VECTOR_DIM=1536
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

PROACTIVE_ENABLED=true
PROACTIVE_INTERVAL_SECONDS=180
PROACTIVE_CONFIDENCE_THRESHOLD=0.72
PROACTIVE_DEDUPE_MINUTES=240
PROACTIVE_THRESHOLD_MIN=0.45
PROACTIVE_THRESHOLD_MAX=0.95
PROACTIVE_ADJUST_ACCEPT=-0.03
PROACTIVE_ADJUST_IGNORE=0.02
PROACTIVE_ADJUST_DISMISS=0.05

AUTH_SESSION_TTL_HOURS=720
AUTH_MIN_PASSWORD_LENGTH=8
